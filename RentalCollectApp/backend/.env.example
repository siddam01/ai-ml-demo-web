ENV=local
APP_NAME=RentFlow Backend
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Recommended: Neon / Supabase (no local Postgres install)
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Local Postgres (if installed)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rentflow

# Docker Compose only (service name "db")
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/rentflow

JWT_SECRET_KEY=change-me-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO
